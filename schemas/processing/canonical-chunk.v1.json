{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://exodus.socioprophet/schemas/processing/canonical-chunk.v1.json",
  "title": "CanonicalChunk",
  "type": "object",
  "required": ["schema_version", "chunk_id", "document_id", "chunk_type", "text", "source_block_ids"],
  "properties": {
    "schema_version": {"type": "string"},
    "chunk_id": {"type": "string"},
    "document_id": {"type": "string"},
    "chunk_type": {"enum": ["paragraph", "section", "table", "caption", "deterministic_window", "adaptive_overlay"]},
    "text": {"type": "string"},
    "source_block_ids": {"type": "array", "items": {"type": "string"}},
    "page_numbers": {"type": "array", "items": {"type": "integer"}},
    "adaptive_model": {"type": ["string", "null"]},
    "provenance": {"type": ["object", "null"]}
  },
  "additionalProperties": false
}
