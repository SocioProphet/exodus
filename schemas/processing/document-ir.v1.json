{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://exodus.socioprophet/schemas/processing/document-ir.v1.json",
  "title": "DocumentIR",
  "type": "object",
  "required": ["schema_version", "document_id", "source_artifact_id", "pages", "blocks"],
  "properties": {
    "schema_version": {"type": "string"},
    "document_id": {"type": "string"},
    "source_artifact_id": {"type": "string"},
    "title": {"type": ["string", "null"]},
    "language": {"type": ["string", "null"]},
    "pages": {"type": "array", "items": {"type": "object", "required": ["page_number"], "properties": {"page_number": {"type": "integer"}, "width": {"type": ["number", "null"]}, "height": {"type": ["number", "null"]}}, "additionalProperties": true}},
    "blocks": {"type": "array", "items": {"type": "object", "required": ["block_id", "block_type", "page_number"], "properties": {"block_id": {"type": "string"}, "block_type": {"type": "string"}, "page_number": {"type": "integer"}, "text": {"type": ["string", "null"]}, "bbox": {"type": ["array", "null"], "items": {"type": "number"}, "minItems": 4, "maxItems": 4}, "source_span": {"type": ["object", "null"]}}, "additionalProperties": true}},
    "tables": {"type": "array", "items": {"type": "object"}},
    "figures": {"type": "array", "items": {"type": "object"}},
    "provenance": {"type": ["object", "null"]}
  },
  "additionalProperties": false
}
