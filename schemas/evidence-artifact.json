{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.socioprophet.ai/exodus/evidence-artifact.v0.1.json",
  "title": "Exodus EvidenceArtifact v0.1",
  "description": "Canonical intake metadata record for artifacts entering the Exodus evidence corpus. Derived from SOCIOPROPHET Metadata Standards v0.1.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_id",
    "corpus_id",
    "exhibit_id",
    "original_filename",
    "mime_type",
    "file_size_bytes",
    "artifact_class",
    "hash_blake3",
    "hash_sha256",
    "canonicalization_spec",
    "serializer_version",
    "hash_computed_at_micros",
    "hash_computed_by",
    "integrity_status",
    "txn_created",
    "observed_at_micros",
    "uploaded_at_micros",
    "source_account",
    "source_platform",
    "source_path_or_id",
    "capture_method",
    "evidence_class",
    "evidence_grade",
    "security_label",
    "witness_retention",
    "owning_zone",
    "custody_status"
  ],
  "properties": {
    "artifact_id": { "$ref": "#/$defs/uuid_v7_or_uuid" },
    "corpus_id": { "type": "string", "minLength": 1 },
    "exhibit_id": { "type": "string", "pattern": "^AF-[0-9]{4,}$" },
    "original_filename": { "type": "string", "minLength": 1 },
    "mime_type": { "type": "string", "minLength": 1 },
    "file_size_bytes": { "type": "integer", "minimum": 0 },
    "artifact_class": { "$ref": "#/$defs/artifact_class" },
    "hash_blake3": { "$ref": "#/$defs/hex_32" },
    "hash_sha256": { "$ref": "#/$defs/hex_32" },
    "hash_md5": { "anyOf": [{ "$ref": "#/$defs/hex_16" }, { "type": "null" }] },
    "canonicalization_spec": { "type": "string", "pattern": "^CANON-v[0-9]+\\.[0-9]+" },
    "serializer_version": { "type": "string", "minLength": 1 },
    "hash_computed_at_micros": { "type": "integer", "minimum": 0 },
    "hash_computed_by": { "type": "string", "minLength": 1 },
    "integrity_status": { "enum": ["Verified", "PendingVerification", "IntegrityViolation", "Unknown"] },
    "txn_created": { "type": "string", "minLength": 1 },
    "valid_from_micros": { "type": ["integer", "null"], "minimum": 0 },
    "valid_to_micros": { "type": ["integer", "null"], "minimum": 0 },
    "observed_at_micros": { "type": "integer", "minimum": 0 },
    "uploaded_at_micros": { "type": "integer", "minimum": 0 },
    "incident_date_range": { "type": ["string", "null"] },
    "source_account": { "type": "string", "minLength": 1 },
    "source_platform": { "$ref": "#/$defs/source_platform" },
    "source_path_or_id": { "type": "string", "minLength": 1 },
    "containing_folder": { "type": ["string", "null"] },
    "producing_tool": { "type": ["string", "null"] },
    "capture_method": { "$ref": "#/$defs/capture_method" },
    "parent_artifact_id": { "anyOf": [{ "$ref": "#/$defs/uuid_v7_or_uuid" }, { "type": "null" }] },
    "signer_atom": { "type": ["string", "null"] },
    "chain_of_trust": { "type": "array", "items": { "type": "string" } },
    "evidence_class": { "enum": ["Primary", "Derived", "Duplicate", "Reference", "Unknown"] },
    "evidence_grade": { "enum": ["E1", "E2", "E3", "E4", "E5"] },
    "layer_citations": { "type": "array", "items": { "type": "string", "pattern": "^L[0-9]{2}-.+" } },
    "hypothesis_ids": { "type": "array", "items": { "type": "string" } },
    "null_hypothesis_ids": { "type": "array", "items": { "type": "string" } },
    "counter_explanations": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "security_label": { "enum": ["Public", "Internal", "Confidential", "Restricted", "LocalOnly"] },
    "witness_retention": { "enum": ["LocalOnly", "ExportableToLegalCounsel", "ExportableUnderProtectiveOrder", "PublicRecord"] },
    "owning_zone": { "$ref": "#/$defs/zone" },
    "custody_status": { "$ref": "#/$defs/custody_status" }
  },
  "$defs": {
    "uuid_v7_or_uuid": { "type": "string", "pattern": "^[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{12}$" },
    "hex_32": { "type": "string", "pattern": "^[0-9a-fA-F]{64}$" },
    "hex_16": { "type": "string", "pattern": "^[0-9a-fA-F]{32}$" },
    "artifact_class": { "enum": ["RawLog", "ConsolePaste", "Spindump", "BinaryPlist", "EmailThread", "LegalFiling", "AnalysisReport", "DerivedReport", "AuditRecord", "NetworkCapture", "FirmwareDump", "AppleDataArchive", "Other"] },
    "source_platform": { "enum": ["GoogleDrive", "GmailThread", "iCloudDrive", "LocalFilesystem", "AppleDataArchive", "TerminalSession", "BrowserConsole", "NetworkCapture", "Other"] },
    "capture_method": { "enum": ["LiveCapture", "PanicSave", "ScheduledExport", "ManualCopy", "AgentExport", "Unknown"] },
    "zone": { "enum": ["Discovery", "Landing", "Examination", "Integration", "Governed", "Diamond", "InFlight"] },
    "custody_status": { "enum": ["Intact", "Gap", "IntegrityViolation", "PendingVerification"] }
  }
}
