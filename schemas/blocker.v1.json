{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "$id": "schemas/blocker.v1.json",
  "required": [
    "blocker_id",
    "title",
    "severity",
    "scope_ref"
  ],
  "properties": {
    "blocker_id": {
      "type": "string"
    },
    "title": {
      "type": "string"
    },
    "severity": {
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high",
        "critical"
      ]
    },
    "scope_ref": {
      "type": "string"
    },
    "kind": {
      "type": "string"
    },
    "notes": {
      "type": "string"
    }
  }
}
